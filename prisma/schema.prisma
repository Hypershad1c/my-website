datasource db {
  provider = "mongodb"
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  price       Float    // MongoDB uses Float for decimals in Prisma
  images      String[]
  stock       Int
  categoryId  String   @db.ObjectId
  category    Category @relation(fields: [categoryId], references: [id])
}

model Category {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  name     String    @unique
  products Product[]
}