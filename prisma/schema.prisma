generator client {
  provider = "prisma-client-js" // Changed to the standard JS client
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Decimal
  images      String[]
  stock       Int
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
}

// Add this block to define the Category
model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[] // This is the "many" side of the relationship
}